# Supabase — get these from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin access — set this to protect /admin routes
ADMIN_SECRET=change-me-in-production

# App base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------
# MOCK MODE
# If NEXT_PUBLIC_SUPABASE_URL is not set, the app
# automatically runs in mock mode with seed data.
# -------------------------------------------------------
